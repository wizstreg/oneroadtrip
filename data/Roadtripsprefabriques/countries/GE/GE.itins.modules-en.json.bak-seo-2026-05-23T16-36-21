            "map_keywords": [
              "Georgian Military Road",
              "Russia-Georgia Friendship Monument",
              "Gudauri Ski Resort",
              "Gudauri Panorama",
              "Krestovy Pass"
            ]
          },
          "visits": [
            {
              "text": "Travel the legendary Georgian Military Highway, one of the most spectacular mountain roads in the world connecting Tbilisi to the high Caucasus. This historic route winds through dramatic gorges, past ancient fortresses, and along rushing rivers that have shaped the landscape for millennia. Every curve reveals new vistas of snow-capped peaks and verdant valleys.",
              "place_id": "",
              "visit_duration_min": 75
            },
            {
              "text": "Stop at the Russia-Georgia Friendship Monument, a striking Soviet-era mosaic panorama built in 1983 to commemorate bilateral relations. The colorful semi-circular structure features intricate tile work depicting scenes from Georgian and Russian history. More importantly, the viewing platform offers spectacular panoramas of the surrounding mountain wilderness.",
              "place_id": "",
              "visit_duration_min": 75
            }
          ],
          "activities": [
            {
              "text": "Discover Gudauri, Georgia's premier mountain resort featuring 35 kilometers of ski slopes served by 15 modern lifts during winter months. In summer, the area transforms into a paradise for hikers and paragliders seeking adventure amid pristine alpine landscapes. The resort sits at an elevation of 2,200 meters, offering refreshing mountain air and dramatic scenery year-round.",
              "place_id": "",
              "activity_duration_min": 60
            }
          ],
