      "seo": {
        "h1_title": "Circuito Turquemenistão: Rota da Seda e Cratera de Darvaza",
        "intro_paragraph": "Aproxime-se de Ashgabat e das suas avenidas de mármore, depois siga rumo a Darvaza para ver a noite abrir-se em redor das chamas do deserto. Explore Merv e as suas ruínas na Rota da Seda, atravesse o Karakum ao ritmo das pistas, depois alcance Kunya-Urgench e os seus minaretes sagrados. O Turquemenistão impressiona pelo seu silêncio mineral e pelos vestígios de impérios.",
        "seo_hook": "Chamas eternas rugindo das areias do deserto, cidades de mármore branco surreais, minaretes guardando impérios esquecidos. O Turquemenistão desafia todas as expectativas.",
        "featured_list": [
          "Darvaza: porta do inferno com chamas eternas",
          "Ashgabat: capital surreal de mármore branco",
          "Merv: ruínas antigas da Rota da Seda",
          "Kunya-Urgench: minaretes sagrados das dinastias"
        ],
        "places_taglines": {
          "TM::ashgabat": "Onde o mármore branco se ergue em delírios de grandeza ditatorial",
          "TM::kowata": "Um lago secreto onde a terra respira vapor nas profundezas",
          "TM::yerbent": "Oásis perdido onde as iurtas sussurram histórias de caravanas",
          "TM::darvaza": "Onde o deserto arde sem cessar numa cratera de fogo eterno",
          "TM::konyeurgench": "Minaretes erguidos ao céu guardam a memória da Rota da Seda",
          "TM::turkmenabad": "Porta de entrada fluvial onde o Amu Dária traça a fronteira",
          "TM::mary": "Antiga Merv: joia arqueológica que reinou sobre a Rota da Seda",
          "TM::turkmenbashi": "Estância fantasma de palácios vazios frente ao Mar Cáspio"
        }
      },
