          "activities": [
            {
              "text": "Saborea sabores tradicionales rumanos maridados con vinos locales en establecimientos de los pueblos. Ya seas un aficionado a la historia fascinado por la arquitectura rural o un amante de la gastronomía buscando probar auténtica cocina regional, Murfatlar ofrece experiencias memorables.",
              "place_id": "",
              "activity_duration_min": 60
            }
