          "visits": [
            {
              "text": "The Viñales Valley (UNESCO 1999) covers 132 km² in the Sierra de los Órganos, a landscape dotted with mogotes — sheer-sided Jurassic limestone formations up to 300 metres tall, some 150 million years old. Spanish sailors thought they looked like organ pipes, giving the sierra its name. The province of Pinar del Río grows around 80% of Cuba's tobacco using entirely traditional methods: ox-drawn ploughs, leaf-by-leaf harvesting, and 45–60 days of curing in wooden tobacco barns.",
              "place_id": "",
              "visit_duration_min": 75
            },
            {
              "text": "The Mural of Prehistory (120 m high, 180 m wide), painted on the face of the Pita mogote between 1961 and 1965 by Leovigildo González Morillo, traces the evolution of life in the sierra. Continue to the Mirador de Los Jazmines for a sweeping panoramic view across the entire valley.",
              "place_id": "",
              "visit_duration_min": 60
            }
          ],
          "activities": [
            {
              "text": "Horseback ride through the Valle del Silencio, passing between mogotes, tobacco fields and cassava plantations. In season (January–March), pickers work the rows by hand. A local farmer will brew you fresh coffee and roll a cigar in front of you — the real thing.",
              "place_id": "",
              "activity_duration_min": 120,
              "practical_info": {
                "duration": "~2h",
                "difficulty": "Easy"
              }
            }
          ]
