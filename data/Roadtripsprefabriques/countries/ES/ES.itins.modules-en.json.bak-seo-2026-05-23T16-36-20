            "map_keywords": [
              "Cala San Pedro Las Negras",
              "Playa de Las Negras",
              "Cerro Negro Las Negras",
              "Castillo de San Pedro Cabo de Gata",
              "Playazo de Rodalquilar",
              "Rodalquilar Cabo de Gata"
            ]
          },
          "visits": [
            {
              "text": "Cala San Pedro must be earned: an hour's walk from Las Negras along a coastal path overlooking the Mediterranean. The ruins of a 15th-century castle guard the entrance to this isolated cove, a former pirate hideout. A freshwater spring—the only one in the park—flows at the beach's edge.",
              "place_id": "",
              "visit_duration_min": 90
            },
            {
              "text": "Las Negras takes its name from Cerro Negro, the dark volcanic mass that dominates the village. About 350 people live here year-round, including many foreigners drawn by the tranquility. Fishing boats still beach on the black pebble shore each evening.",
              "place_id": "",
              "visit_duration_min": 45
            },
            {
              "text": "Take the road to Rodalquilar, a former mining village reinvented. The ruins of the gold mines, worked until 1966, can be freely visited. The El Albardinal Botanical Garden showcases the park's semi-arid flora.",
              "place_id": "",
              "visit_duration_min": 60
            },
            {
              "text": "The Playazo de Rodalquilar offers a striking contrast with the enclosed coves: 400 meters of golden sand bordered by the Playazo tower, an 18th-century fortification. The water here is calm and shallow.",
              "place_id": "",
              "visit_duration_min": 45
            },
            {
              "text": "From the trail above Cerro Negro, viewpoints offer spectacular vistas of black cliffs plunging into the sea and, in the distance, the silhouette of Isleta del Moro.",
              "place_id": "",
              "visit_duration_min": 30
            }
          ],
          "activities": [
            {
              "text": "Hike Las Negras to Cala San Pedro via the coastal trail. The route crosses semi-arid landscape punctuated by red and yellow cliffs before diving toward the turquoise cove.",
              "place_id": "",
              "activity_duration_min": 180,
              "practical_info": {
                "distance": "10.6 km round trip",
                "duration": "~3h-3h30",
                "difficulty": "Moderate",
                "tip": "No shade on the route, bring water and hat"
              }
            },
            {
              "text": "Kayak along the volcanic cliffs from Las Negras. Rental shops offer guided outings that follow caves and rock formations inaccessible by land.",
              "place_id": "",
              "activity_duration_min": 90,
              "practical_info": {
                "duration": "1h30",
                "booking": "Reservation recommended in summer"
              }
            },
            {
              "text": "Snorkeling in the coves around Las Negras. The volcanic rocky seabeds create varied habitats for Mediterranean underwater fauna.",
              "place_id": "",
              "activity_duration_min": 60
            },
            {
              "text": "Evening drinks facing the sea on the Las Negras promenade. The village's bohemian vibe carries through to the small waterfront bars.",
              "place_id": "",
              "activity_duration_min": 45
            }
          ],
