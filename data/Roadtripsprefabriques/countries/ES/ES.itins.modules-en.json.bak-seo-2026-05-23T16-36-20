            "map_keywords": [
              "Desierto de Tabernas Almería",
              "Oasys MiniHollywood Tabernas",
              "Fort Bravo Texas Hollywood Tabernas",
              "Castillo de Tabernas",
              "Plataforma Solar de Almería Tabernas",
              "Mirador Desierto de Tabernas"
            ]
          },
          "visits": [
            {
              "text": "The Tabernas Desert stretches across 280 km², Europe's only true desert with less than 250mm of annual rainfall. The ravines, canyons, and badlands in ochre hues recall American West landscapes—which attracted filmmakers from the 1950s onward.",
              "place_id": "",
              "visit_duration_min": 60
            },
            {
              "text": "Fort Bravo preserves Europe's finest western film sets, built in the 1960s for Sergio Leone's films. The wooden Far West town, Mexican village, and military fort still serve as active filming locations. Stunt and shootout shows are performed on weekends.",
              "place_id": "",
              "visit_duration_min": 90
            },
            {
              "text": "Oasys MiniHollywood, on the filming locations of A Fistful of Dollars and The Good, the Bad and the Ugly, has been transformed into a theme park. The reconstructed western town, 800-animal wildlife reserve, and cactus garden round out the visit.",
              "place_id": "",
              "visit_duration_min": 90
            },
            {
              "text": "The Castillo de Tabernas, an 11th-century Arab fortress, dominates the village from its hill. Though in ruins but undergoing restoration, it offers panoramic views over the desert and the Río Andarax valley.",
              "place_id": "",
              "visit_duration_min": 30
            },
            {
              "text": "The Plataforma Solar de Almería, a solar thermal energy research center, takes advantage of the desert's 3,000 hours of annual sunshine. Its giant parabolic mirrors are visible from the road.",
              "place_id": "",
              "visit_duration_min": 30
            }
          ],
          "activities": [
            {
              "text": "Hike through the desert badlands on the GR-140 trail. From Oasys, a 9km route crosses plateaus, canyons, and ravines among eroded sandstone and clay formations.",
              "place_id": "",
              "activity_duration_min": 150,
              "practical_info": {
                "distance": "9 km (short version)",
                "duration": "~3h",
                "difficulty": "Moderate",
                "tip": "No shade, bring minimum 2L of water"
              }
            },
            {
              "text": "Photography walk through the desert landscapes. The golden hours (sunrise and sunset) offer raking light that sculpts the relief and brings out the colors in geological strata.",
              "place_id": "",
              "activity_duration_min": 60
            },
            {
              "text": "Stargazing in the Tabernas Desert. Low light pollution and almost permanently clear skies make it one of Andalusia's best astronomical sites.",
              "place_id": "",
              "activity_duration_min": 60,
              "practical_info": {
                "best_time": "From 10pm, moonless nights",
                "tip": "Warm blanket recommended, desert nights are cool"
              }
            }
          ],
